# =============================================================================
# TravelSphere Platform — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# For local dev, most defaults work out of the box.
# =============================================================================

# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=travelsphere
POSTGRES_USER=travelsphere
POSTGRES_PASSWORD=TravelSphere@2024

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=Redis@2024

# ── Kafka ───────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SCHEMA_REGISTRY_URL=http://localhost:8081

# ── Qdrant (Vector DB) ─────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# ── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=TravelSphere_JWT_Secret_Key_Min32Chars_2024
JWT_ACCESS_TOKEN_EXPIRATION=900000        # 15 minutes in milliseconds
JWT_REFRESH_TOKEN_EXPIRATION=604800000    # 7 days in milliseconds

# ── Eureka ──────────────────────────────────────────────────────────────────
EUREKA_SERVER_URL=http://localhost:8761/eureka

# ── Config Server ──────────────────────────────────────────────────────────
CONFIG_SERVER_URL=http://localhost:8888

# ── AWS / LocalStack ───────────────────────────────────────────────────────
# Dev: uses LocalStack (http://localhost:4566). Only set real AWS creds for prod.
AWS_ACCESS_KEY_ID=fake-access-key
AWS_SECRET_ACCESS_KEY=fake-secret-key
AWS_REGION=ap-south-1
S3_ENDPOINT=http://localhost:4566
S3_BUCKET_DOCUMENTS=travelsphere-documents
S3_BUCKET_PHOTOS=travelsphere-photos

# ── Ollama (Local LLM) ─────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.2
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ── Notification ───────────────────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@travelsphere.com

# ── Spring Profiles ────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev
